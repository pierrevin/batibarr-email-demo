# Supabase (côté serveur uniquement)
SUPABASE_URL=https://xxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Auth démo
DEMO_EMAIL=demo@batibarr.fr
# Générer avec: node -e "const b=require('bcryptjs'); console.log(b.hashSync('votre-mot-de-passe-fort', 12));"
DEMO_PASSWORD_HASH=$2b$12$replace_me_with_bcrypt_hash
# Optionnel (si absent, la valeur DEMO_PASSWORD_HASH est utilisée)
DEMO_SESSION_SECRET=change-me-session-secret

